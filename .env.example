# ============================================================================
# DentiCare Pro - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------------------------------------------
# Resend (Email - Primary OTP Channel)
# ----------------------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys
VITE_RESEND_API_KEY=re_your_resend_api_key
VITE_EMAIL_FROM=DentiCare Pro <noreply@denticare.example.com>

# ----------------------------------------------------------------------------
# WhatsApp Business API (360dialog) - Secondary Channel
# ----------------------------------------------------------------------------
# Get your API key from: https://app.360dialog.io/
VITE_WHATSAPP_API_KEY=your_360dialog_api_key
VITE_WHATSAPP_BUSINESS_ID=your_whatsapp_business_id
VITE_WHATSAPP_WABA_ID=your_waba_id

# ----------------------------------------------------------------------------
# SMS (Zenziva/Twilio) - Tertiary Channel
# ----------------------------------------------------------------------------
# Zenziva
VITE_ZENZIVA_USER_KEY=your_zenziva_user_key
VITE_ZENZIVA_PASS_KEY=your_zenziva_pass_key

# Twilio (alternative)
# VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
# VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token
# VITE_TWILIO_PHONE_NUMBER=+1234567890

# ----------------------------------------------------------------------------
# Midtrans (Payment Gateway)
# ----------------------------------------------------------------------------
# Get your keys from: https://dashboard.midtrans.com
VITE_MIDTRANS_CLIENT_KEY=your_midtrans_client_key
VITE_MIDTRANS_SNAP_URL=https://app.midtrans.com/snap

# ----------------------------------------------------------------------------
# App Settings
# ----------------------------------------------------------------------------
VITE_CLINIC_NAME=DentiCare Pro
VITE_CLINIC_ADDRESS=Jl. Raya Klinik Gigi No. 1
VITE_CLINIC_PHONE=+62-21-12345678
VITE_CLINIC_EMAIL=info@denticare.example.com
VITE_PORTAL_URL=http://localhost:5173/portal
